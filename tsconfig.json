{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",              // ✅ CHANGE THIS
    "moduleResolution": "Node16",    // ✅ KEEP THIS
    "lib": ["ES2020"],
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}